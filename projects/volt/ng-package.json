{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/volt",
  "lib": {
    "entryFile": "src/public-api.ts"
  },
  "assets": [
    {
      "glob": "themes.css",
      "input": "src",
      "output": "."
    },
    {
      "glob": "**/*.css",
      "input": "src/themes",
      "output": "themes"
    }
  ],
  "allowedNonPeerDependencies": [
    "class-variance-authority",
    "clsx",
    "tailwind-merge",
    "ng-primitives",
    "@floating-ui/dom"
  ]
}
