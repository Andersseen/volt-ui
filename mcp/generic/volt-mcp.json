{
  "schema_version": "1.0",
  "name": "volt-ui",
  "display_name": "Volt UI",
  "description": "Angular v21 component library built on ng-primitives with Tailwind CSS",
  "version": "1.0.0",
  "author": "Volt UI Team",
  "license": "MIT",
  "project": {
    "type": "angular-component-library",
    "framework": {
      "name": "Angular",
      "version": "21.x"
    },
    "language": "TypeScript",
    "styling": {
      "framework": "Tailwind CSS",
      "version": "4.x"
    },
    "primitives": {
      "name": "ng-primitives",
      "description": "Accessible Angular component primitives"
    },
    "variants": {
      "library": "class-variance-authority",
      "description": "Type-safe component variants"
    }
  },
  "architecture": {
    "components": {
      "type": "standalone",
      "modules": false
    },
    "change_detection": "zoneless-signals",
    "reactivity": {
      "type": "signals",
      "apis": ["input", "output", "model", "computed"]
    },
    "accessibility": {
      "approach": "host-directives",
      "library": "ng-primitives"
    }
  },
  "naming_conventions": {
    "library": {
      "selector_prefix": "volt",
      "class_prefix": "Volt",
      "example": {
        "selector": "volt-button",
        "class": "VoltButton"
      }
    },
    "cli_output": {
      "selector_prefix": "ui",
      "class_prefix": "Ui",
      "example": {
        "selector": "ui-button",
        "class": "UiButton"
      }
    }
  },
  "source_structure": {
    "root": "projects/volt",
    "components_path": "src/lib",
    "themes_path": "src/themes",
    "public_api": "src/public-api.ts"
  },
  "cli": {
    "path": "cli/bin/volt",
    "commands": {
      "init": {
        "description": "Initialize Volt UI in a project",
        "usage": "volt init [target-directory]",
        "default_target": "./src/app/ui"
      },
      "add": {
        "description": "Add a component to the project",
        "usage": "volt add <component-name> [target-directory]",
        "transformations": [
          "Replace volt-* selectors with ui-*",
          "Replace Volt* class names with Ui*",
          "Update imports to local paths"
        ]
      },
      "list": {
        "description": "List all available components"
      }
    }
  },
  "components": {
    "button": {
      "name": "button",
      "description": "Button component with multiple variants and sizes",
      "files": ["button.ts", "index.ts"],
      "dependencies": ["ng-primitives/button"],
      "variants": ["solid", "outline", "ghost", "link", "destructive"],
      "sizes": ["sm", "md", "lg", "icon"],
      "inputs": ["variant", "size", "disabled"]
    },
    "badge": {
      "name": "badge",
      "description": "Badge component for labels and counts",
      "files": ["badge.ts", "index.ts"],
      "dependencies": [],
      "variants": ["default", "secondary", "outline", "destructive"]
    },
    "card": {
      "name": "card",
      "description": "Card container with header, content, and footer",
      "files": ["card.component.ts", "index.ts"],
      "dependencies": [],
      "sub_components": [
        "card-header",
        "card-title",
        "card-description",
        "card-content",
        "card-footer"
      ]
    },
    "input": {
      "name": "input",
      "description": "Text input field",
      "files": ["input.component.ts", "index.ts"],
      "dependencies": [],
      "inputs": ["type", "placeholder", "disabled"]
    },
    "textarea": {
      "name": "textarea",
      "description": "Multi-line text input",
      "files": ["textarea.ts", "index.ts"],
      "dependencies": [],
      "inputs": ["rows", "placeholder", "disabled"]
    },
    "checkbox": {
      "name": "checkbox",
      "description": "Checkbox input with indeterminate state",
      "files": ["checkbox.component.ts", "index.ts"],
      "dependencies": ["ng-primitives/checkbox"],
      "inputs": ["checked", "disabled", "indeterminate"]
    },
    "radio": {
      "name": "radio",
      "description": "Radio group and radio items",
      "files": ["radio-group.ts", "radio-item.ts", "index.ts"],
      "dependencies": ["ng-primitives/radio"],
      "inputs": ["value", "disabled", "required"]
    },
    "switch": {
      "name": "switch",
      "description": "Toggle switch component",
      "files": ["switch.component.ts", "index.ts"],
      "dependencies": ["ng-primitives/switch"],
      "inputs": ["checked", "disabled"]
    },
    "toggle": {
      "name": "toggle",
      "description": "Toggle button (pressed state)",
      "files": ["toggle.ts", "index.ts"],
      "dependencies": ["ng-primitives/button"],
      "inputs": ["pressed", "disabled"]
    },
    "select": {
      "name": "select",
      "description": "Dropdown select with options",
      "files": [
        "select.component.ts",
        "select-content.component.ts",
        "select-item.component.ts",
        "select-label.component.ts",
        "select-separator.component.ts",
        "index.ts"
      ],
      "dependencies": ["ng-primitives/select"],
      "sub_components": ["select-content", "select-item", "select-label", "select-separator"],
      "inputs": ["value", "placeholder", "disabled", "multiple"]
    },
    "tabs": {
      "name": "tabs",
      "description": "Tabbed interface",
      "files": [
        "tabs.component.ts",
        "tabs-list.component.ts",
        "tabs-trigger.component.ts",
        "tabs-content.component.ts"
      ],
      "dependencies": ["ng-primitives/tab"],
      "sub_components": ["tabs-list", "tabs-trigger", "tabs-content"],
      "inputs": ["value"]
    },
    "accordion": {
      "name": "accordion",
      "description": "Collapsible accordion panels",
      "files": [
        "accordion.component.ts",
        "accordion-item.component.ts",
        "accordion-trigger.component.ts",
        "accordion-content.component.ts",
        "index.ts"
      ],
      "dependencies": ["ng-primitives/accordion"],
      "sub_components": ["accordion-item", "accordion-trigger", "accordion-content"],
      "inputs": ["type", "collapsible", "value"]
    },
    "avatar": {
      "name": "avatar",
      "description": "User avatar with image and fallback",
      "files": ["avatar.ts", "avatar-image.ts", "avatar-fallback.ts", "index.ts"],
      "dependencies": ["ng-primitives/avatar"],
      "sub_components": ["avatar-image", "avatar-fallback"],
      "inputs": ["src", "alt", "delayMs"]
    },
    "separator": {
      "name": "separator",
      "description": "Visual divider line",
      "files": ["separator.component.ts", "index.ts"],
      "dependencies": ["ng-primitives/separator"],
      "inputs": ["orientation"]
    },
    "tooltip": {
      "name": "tooltip",
      "description": "Floating tooltip on hover",
      "files": ["tooltip.ts", "tooltip-content.ts", "index.ts"],
      "dependencies": ["ng-primitives/tooltip"],
      "sub_components": ["tooltip-content"],
      "inputs": ["content", "side", "align", "delay"]
    },
    "navigation-menu": {
      "name": "navigation-menu",
      "description": "Navigation menu with dropdowns",
      "files": [
        "navigation-menu.ts",
        "navigation-menu-list.ts",
        "navigation-menu-item.ts",
        "navigation-menu-trigger.ts",
        "navigation-menu-content.ts",
        "navigation-menu-content-item.ts",
        "navigation-menu-link.ts",
        "index.ts"
      ],
      "dependencies": ["ng-primitives/navigation-menu"],
      "sub_components": [
        "navigation-menu-list",
        "navigation-menu-item",
        "navigation-menu-trigger",
        "navigation-menu-content",
        "navigation-menu-content-item",
        "navigation-menu-link"
      ],
      "inputs": ["value"]
    },
    "form-field": {
      "name": "form-field",
      "description": "Form field wrapper with label, hint, error",
      "files": [
        "form-field.ts",
        "form-field-label.ts",
        "form-field-hint.ts",
        "form-field-error.ts",
        "index.ts"
      ],
      "dependencies": ["ng-primitives/form-field"],
      "sub_components": ["form-field-label", "form-field-hint", "form-field-error"]
    }
  },
  "themes": {
    "system": {
      "type": "css-variables",
      "provider": "provideVoltTheme",
      "dynamic": "applyVoltTheme"
    },
    "colors": {
      "available": ["volt", "ember", "sage", "dusk", "glacier"],
      "default": "volt"
    },
    "styles": {
      "available": ["sharp", "soft", "brutal", "ghost", "retro"],
      "default": "sharp"
    },
    "variables": [
      "--color-background",
      "--color-foreground",
      "--color-surface",
      "--color-surface-foreground",
      "--color-primary",
      "--color-primary-foreground",
      "--color-destructive",
      "--color-destructive-foreground",
      "--color-muted",
      "--color-muted-foreground",
      "--color-border",
      "--color-ring",
      "--color-input",
      "--radius-sm",
      "--radius-md",
      "--radius-lg",
      "--radius-xl"
    ]
  },
  "usage": {
    "installation": {
      "dependencies": "npm install ng-primitives class-variance-authority",
      "cli_init": "node /path/to/volt-ui/cli/bin/volt init",
      "cli_add": "node /path/to/volt-ui/cli/bin/volt add <component>"
    },
    "import_pattern": "import { Ui{Component} } from './ui/{component}';",
    "component_usage": "<{selector} [input]=\"value\">Content</{selector}>",
    "theme_usage": {
      "provider": "provideVoltTheme({ color: 'ember', style: 'soft', dark: false })",
      "dynamic": "applyVoltTheme({ color: 'dusk', style: 'brutal', dark: true })"
    }
  },
  "mcp_endpoints": {
    "component_list": "/components",
    "component_detail": "/components/{name}",
    "theme_info": "/themes",
    "cli_reference": "/cli",
    "quickstart": "/quickstart"
  }
}
