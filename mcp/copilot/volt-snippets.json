{
  "Volt UI Button": {
    "prefix": ["volt-button", "ui-button"],
    "description": "Volt UI Button component",
    "body": ["<ui-button variant=\"${1:solid}\" size=\"${2:md}\">${3:Click me}</ui-button>"]
  },
  "Volt UI Card": {
    "prefix": ["volt-card", "ui-card"],
    "description": "Volt UI Card with full structure",
    "body": [
      "<ui-card>",
      "  <ui-card-header>",
      "    <ui-card-title>${1:Card Title}</ui-card-title>",
      "    <ui-card-description>${2:Card description}</ui-card-description>",
      "  </ui-card-header>",
      "  <ui-card-content>",
      "    ${3:<!-- Content -->}",
      "  </ui-card-content>",
      "  <ui-card-footer>",
      "    <ui-button variant=\"outline\">${4:Cancel}</ui-button>",
      "    <ui-button>${5:Confirm}</ui-button>",
      "  </ui-card-footer>",
      "</ui-card>"
    ]
  },
  "Volt UI Form Field": {
    "prefix": ["volt-form-field", "ui-form-field"],
    "description": "Volt UI Form Field with input",
    "body": [
      "<ui-form-field>",
      "  <ui-form-field-label>${1:Label}</ui-form-field-label>",
      "  <ui-input type=\"${2:text}\" placeholder=\"${3:Enter value}\" />",
      "  <ui-form-field-hint>${4:Helper text}</ui-form-field-hint>",
      "</ui-form-field>"
    ]
  },
  "Volt UI Tabs": {
    "prefix": ["volt-tabs", "ui-tabs"],
    "description": "Volt UI Tabs component",
    "body": [
      "<ui-tabs value=\"${1:tab1}\">",
      "  <ui-tabs-list>",
      "    <ui-tabs-trigger value=\"${1:tab1}\">${2:Tab 1}</ui-tabs-trigger>",
      "    <ui-tabs-trigger value=\"${3:tab2}\">${4:Tab 2}</ui-tabs-trigger>",
      "  </ui-tabs-list>",
      "  <ui-tabs-content value=\"${1:tab1}\">${5:Content 1}</ui-tabs-content>",
      "  <ui-tabs-content value=\"${3:tab2}\">${6:Content 2}</ui-tabs-content>",
      "</ui-tabs>"
    ]
  },
  "Volt UI Import Button": {
    "prefix": ["volt-import-button", "import-ui-button"],
    "description": "Import Volt UI Button",
    "body": ["import { UiButton } from './ui/button';"]
  },
  "Volt UI Import Card": {
    "prefix": ["volt-import-card", "import-ui-card"],
    "description": "Import Volt UI Card components",
    "body": [
      "import { UiCard, UiCardHeader, UiCardTitle, UiCardDescription, UiCardContent, UiCardFooter } from './ui/card';"
    ]
  },
  "Volt UI Import Form": {
    "prefix": ["volt-import-form", "import-ui-form"],
    "description": "Import Volt UI Form components",
    "body": [
      "import { UiFormField, UiFormFieldLabel, UiFormFieldHint, UiFormFieldError } from './ui/form-field';",
      "import { UiInput } from './ui/input';"
    ]
  },
  "Volt UI Checkbox": {
    "prefix": ["volt-checkbox", "ui-checkbox"],
    "description": "Volt UI Checkbox",
    "body": ["<ui-checkbox [(checked)]=\"${1:checked}\">${2:Label}</ui-checkbox>"]
  },
  "Volt UI Select": {
    "prefix": ["volt-select", "ui-select"],
    "description": "Volt UI Select dropdown",
    "body": [
      "<ui-select placeholder=\"${1:Select option}\">",
      "  <ui-select-label>${2:Label}</ui-select-label>",
      "  <ui-select-content>",
      "    <ui-select-item value=\"${3:value1}\">${4:Option 1}</ui-select-item>",
      "    <ui-select-item value=\"${5:value2}\">${6:Option 2}</ui-select-item>",
      "  </ui-select-content>",
      "</ui-select>"
    ]
  },
  "Volt UI Avatar": {
    "prefix": ["volt-avatar", "ui-avatar"],
    "description": "Volt UI Avatar",
    "body": [
      "<ui-alt [src]=\"'${1:https://...}'\" [alt]=\"'${2:User}'\">",
      "  <ui-avatar-fallback>${3:JD}</ui-avatar-fallback>",
      "</ui-avatar>"
    ]
  },
  "Volt UI Tooltip": {
    "prefix": ["volt-tooltip", "ui-tooltip"],
    "description": "Volt UI Tooltip",
    "body": [
      "<ui-tooltip content=\"${1:Tooltip text}\">",
      "  <ui-button variant=\"ghost\" size=\"icon\">${2:?}</ui-button>",
      "</ui-tooltip>"
    ]
  },
  "Volt UI Accordion": {
    "prefix": ["volt-accordion", "ui-accordion"],
    "description": "Volt UI Accordion",
    "body": [
      "<ui-accordion type=\"${1:single}\" [collapsible]=\"true\">",
      "  <ui-accordion-item>",
      "    <ui-accordion-trigger>${2:Section 1}</ui-accordion-trigger>",
      "    <ui-accordion-content>${3:Content 1}</ui-accordion-content>",
      "  </ui-accordion-item>",
      "</ui-accordion>"
    ]
  },
  "Volt UI Separator": {
    "prefix": ["volt-separator", "ui-separator"],
    "description": "Volt UI Separator",
    "body": ["<ui-separator orientation=\"${1|horizontal,vertical|}\" />"]
  },
  "Volt UI Switch": {
    "prefix": ["volt-switch", "ui-switch"],
    "description": "Volt UI Switch",
    "body": ["<ui-switch [(checked)]=\"${1:checked}\">${2:Label}</ui-switch>"]
  },
  "Volt UI Radio": {
    "prefix": ["volt-radio", "ui-radio"],
    "description": "Volt UI Radio Group",
    "body": [
      "<ui-radio-group [(value)]=\"${1:selectedValue}\">",
      "  <ui-radio-item value=\"${2:option1}\">${3:Option 1}</ui-radio-item>",
      "  <ui-radio-item value=\"${4:option2}\">${5:Option 2}</ui-radio-item>",
      "</ui-radio-group>"
    ]
  },
  "Volt UI Toggle": {
    "prefix": ["volt-toggle", "ui-toggle"],
    "description": "Volt UI Toggle Button",
    "body": ["<ui-toggle [(pressed)]=\"${1:pressed}\">${2:Toggle}</ui-toggle>"]
  },
  "Volt UI Navigation Menu": {
    "prefix": ["volt-nav-menu", "ui-nav-menu"],
    "description": "Volt UI Navigation Menu",
    "body": [
      "<ui-navigation-menu>",
      "  <ui-navigation-menu-list>",
      "    <ui-navigation-menu-item>",
      "      <ui-navigation-menu-trigger>${1:Item}</ui-navigation-menu-trigger>",
      "      <ui-navigation-menu-content>",
      "        <ui-navigation-menu-link>${2:Link}</ui-navigation-menu-link>",
      "      </ui-navigation-menu-content>",
      "    </ui-navigation-menu-item>",
      "  </ui-navigation-menu-list>",
      "</ui-navigation-menu>"
    ]
  },
  "Volt CLI Add": {
    "prefix": ["volt-add", "volt-cli-add"],
    "description": "Add Volt UI component via CLI",
    "body": ["node /path/to/volt-ui/cli/bin/volt add ${1:button}"]
  },
  "Volt CLI Init": {
    "prefix": ["volt-init", "volt-cli-init"],
    "description": "Initialize Volt UI in project",
    "body": ["node /path/to/volt-ui/cli/bin/volt init ${1:./src/app/ui}"]
  },
  "Volt Theme Provider": {
    "prefix": ["volt-theme", "provide-volt-theme"],
    "description": "Provide Volt theme in app config",
    "body": [
      "import { provideVoltTheme } from 'volt/theme';",
      "",
      "providers: [",
      "  provideVoltTheme({",
      "    color: '${1|volt,ember,sage,dusk,glacier|}',",
      "    style: '${2|sharp,soft,brutal,ghost,retro|}',",
      "    dark: ${3|false,true|}",
      "  })",
      "]"
    ]
  },
  "Volt Component Class": {
    "prefix": ["volt-component", "volt-class"],
    "description": "Volt UI Component class template",
    "body": [
      "import { ChangeDetectionStrategy, Component, computed, input } from '@angular/core';",
      "import { cva, type VariantProps } from 'class-variance-authority';",
      "",
      "export const ${1:component}Variants = cva('${2:base-classes}', {",
      "  variants: {",
      "    variant: {",
      "      default: '${3:}',",
      "      ${4:secondary}: '${5:}'",
      "    }",
      "  },",
      "  defaultVariants: {",
      "    variant: 'default'",
      "  }",
      "});",
      "",
      "export type ${6:Component}Variants = VariantProps<typeof ${1:component}Variants>;",
      "",
      "@Component({",
      "  selector: 'ui-${7:component}',",
      "  template: \`${8:<ng-content />}\`,",
      "  changeDetection: ChangeDetectionStrategy.OnPush",
      "})",
      "export class Ui${6:Component} {",
      "  readonly variant = input<${6:Component}Variants['variant']>('default');",
      "  protected readonly classes = computed(() => ${1:component}Variants({ variant: this.variant() }));",
      "}"
    ]
  }
}
