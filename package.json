{
  "name": "volt-ui",
  "version": "0.0.0",
  "bin": {
    "volt": "./cli/bin/volt"
  },
  "scripts": {
    "ng": "ng",
    "start": "NODE_OPTIONS='--max-old-space-size=4096' ng serve",
    "start:safe": "ng serve --poll=2000 --live-reload=false",
    "dev": "./scripts/dev.sh",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' ng build",
    "build:prod": "NODE_OPTIONS='--max-old-space-size=8192' ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "clean": "rm -rf .angular node_modules/.cache dist",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "deploy": "pnpm run deploy:cf:main",
    "deploy:cf": "pnpm run build && pnpm exec wrangler pages deploy dist/volt-ui/browser --project-name=volt-ui",
    "deploy:cf:main": "pnpm run build && pnpm exec wrangler pages deploy dist/volt-ui/browser --project-name=volt-ui --branch=main"
  },
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "@angular/animations": "^21.2.2",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@floating-ui/dom": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cva": "^0.0.0",
    "ng-primitives": "0.110.2",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "4.2.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@ng-primitives/mcp": "^0.110.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.72.0"
  }
}
