{
  "name": "volt-ui",
  "version": "0.1.0",
  "bin": {
    "volt": "./cli/bin/volt",
    "volt-ui-mcp": "./cli/setup-mcp.js"
  },
  "scripts": {
    "setup:mcp": "node cli/setup-mcp.js",
    "start": "vite",
    "dev": "vite",
    "predev": "node cli/generate-manifest.js",
    "build": "vite build",
    "prebuild": "node cli/generate-manifest.js",
    "build:prod": "vite build",
    "watch": "vite build --watch",
    "clean": "rm -rf node_modules/.cache dist",
    "preview": "wrangler pages dev dist/analog/public",
    "test": "vitest",
    "pretest": "node cli/generate-manifest.js",
    "test:run": "vitest --run",
    "pretest:run": "node cli/generate-manifest.js",
    "test:coverage": "vitest run --coverage",
    "pretest:coverage": "node cli/generate-manifest.js",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ci": "pnpm build && E2E_SERVER=preview E2E_PORT=5174 playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm lint && pnpm typecheck && pnpm test:run && pnpm build:lib && pnpm test:e2e:ci",
    "lint": "eslint . --ext .ts,.html",
    "lint:fix": "eslint . --ext .ts,.html --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "typecheck:watch": "tsc --noEmit --project tsconfig.json --watch",
    "deploy": "pnpm run deploy:cf:main",
    "deploy:cf": "pnpm run build && pnpm exec wrangler pages deploy dist/analog/public --project-name=volt-ui",
    "deploy:cf:main": "pnpm run build && pnpm exec wrangler pages deploy dist/analog/public --project-name=volt-ui --branch=main",
    "build:lib": "ng build volt",
    "pack:cli": "cd cli && npm pack --dry-run",
    "publish:lib": "ng build volt && cd dist/volt && npm publish --access public",
    "prepare": "husky",
    "manifest": "node cli/generate-manifest.js"
  },
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@analogjs/content": "^2.6.1",
    "@analogjs/platform": "^2.6.1",
    "@analogjs/router": "^2.6.1",
    "@angular/animations": "^21.2.2",
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.2",
    "@angular/compiler": "^21.2.2",
    "@angular/core": "^21.2.2",
    "@angular/forms": "^21.2.2",
    "@angular/platform-browser": "^21.2.2",
    "@angular/platform-server": "^21.2.2",
    "@angular/router": "^21.2.2",
    "@floating-ui/dom": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lumen-icons": "^0.1.0",
    "ng-primitives": "0.110.2",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular-eslint/utils": "^21.3.1",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.2",
    "@eslint/js": "^10.0.1",
    "@ng-primitives/mcp": "^0.110.2",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.8",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "h3": "1.15.11",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^21.2.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.8",
    "wrangler": "^4.72.0"
  }
}
