#!/usr/bin/env node

const https = require('https');
const fs = require('fs');
const path = require('path');

const GITHUB_RAW_BASE =
  'https://raw.githubusercontent.com/Andersseen/volt-ui/main/projects/volt/src/lib';

const components = {
  button: {
    files: ['button/button.ts', 'button/index.ts'],
    dependencies: [],
  },
  badge: {
    files: ['badge/badge.ts', 'badge/index.ts'],
    dependencies: [],
  },
  input: {
    files: ['input/input.component.ts', 'input/index.ts'],
    dependencies: [],
  },
  textarea: {
    files: ['textarea/textarea.ts', 'textarea/index.ts'],
    dependencies: [],
  },
  card: {
    files: ['card/card.component.ts', 'card/index.ts'],
    dependencies: [],
  },
  checkbox: {
    files: ['checkbox/checkbox.component.ts', 'checkbox/index.ts'],
    dependencies: [],
  },
  radio: {
    files: ['radio/radio-group.ts', 'radio/radio-item.ts', 'radio/index.ts'],
    dependencies: [],
  },
  switch: {
    files: ['switch/switch.component.ts', 'switch/index.ts'],
    dependencies: [],
  },
  toggle: {
    files: ['toggle/toggle.ts', 'toggle/index.ts'],
    dependencies: [],
  },
  select: {
    files: [
      'select/select.component.ts',
      'select/select-content.component.ts',
      'select/select-item.component.ts',
      'select/select-label.component.ts',
      'select/select-separator.component.ts',
      'select/index.ts',
    ],
    dependencies: [],
  },
  tabs: {
    files: [
      'tabs/tabs.component.ts',
      'tabs/tabs-list.component.ts',
      'tabs/tabs-trigger.component.ts',
      'tabs/tabs-content.component.ts',
    ],
    dependencies: [],
  },
  accordion: {
    files: [
      'accordion/accordion.component.ts',
      'accordion/accordion-item.component.ts',
      'accordion/accordion-trigger.component.ts',
      'accordion/accordion-content.component.ts',
      'accordion/index.ts',
    ],
    dependencies: [],
  },
  avatar: {
    files: ['avatar/avatar.ts', 'avatar/avatar-image.ts', 'avatar/avatar-fallback.ts', 'avatar/index.ts'],
    dependencies: [],
  },
  separator: {
    files: ['separator/separator.component.ts', 'separator/index.ts'],
