function transformContent(content, componentName) {
  // Replace selector volt- with ui-
  content = content.replace(/selector:\s*['"]([^'"]*)['"]/g, (match, selector) => {
    const newSelector = selector.replace(/volt-/g, 'ui-');
    return `selector: '${newSelector}'`;
  });

  // Replace class names VoltXxx with UiXxx
  content = content.replace(/class\s+(Volt\w+)/g, (match, className) => {
    const newClassName = className.replace('Volt', 'Ui');
    return `class ${newClassName}`;
  });

  // Replace export names
  content = content.replace(/export\s+\{\s*(Volt\w+)\s*\}/g, (match, className) => {
    const newClassName = className.replace('Volt', 'Ui');
    return `export { ${newClassName} }`;
  });

  // Replace imports from 'volt'
  content = content.replace(/from\s+['"]volt['"]/g, "from './index'");
  content = content.replace(/from\s+['"]\.\.\/index['"]/g, "from '../index'");

  return content;
}

function getComponentDir(targetDir, componentName) {
  return path.join(targetDir, componentName);
}

function copyComponent(componentName, targetDir = './src/app/ui') {
  const component = components[componentName];
  
  if (!component) {
    console.error(`❌ Component "${componentName}" not found.`);
    console.log('Available components:');
    Object.keys(components).forEach(name => console.log(`  - ${name}`));
    process.exit(1);
  }

  const componentDir = getComponentDir(targetDir, componentName);
  
  // Create directory
  if (!fs.existsSync(componentDir)) {
    fs.mkdirSync(componentDir, { recursive: true });
  }

  // Copy and transform files
  component.files.forEach(file => {
    const sourcePath = path.join(COMPONENTS_DIR, file);
    const fileName = path.basename(file);
    const targetPath = path.join(componentDir, fileName);

    if (!fs.existsSync(sourcePath)) {
      console.error(`❌ Source file not found: ${sourcePath}`);
      return;
    }

    let content = fs.readFileSync(sourcePath, 'utf-8');
    content = transformContent(content, componentName);

    fs.writeFileSync(targetPath, content);
    console.log(`  ✓ Created ${path.relative(process.cwd(), targetPath)}`);
  });

  console.log(`\n✅ Component "${componentName}" added successfully!`);
  console.log(`\nImport in your component:`);
  console.log(`  import { Ui${capitalize(componentName.replace(/-/g, ' ')).replace(/\s/g, '')} } from './ui/${componentName}';`);
}

function capitalize(str) {
  return str.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
}

function initProject(targetDir = './src/app/ui') {
  if (!fs.existsSync(targetDir)) {
    fs.mkdirSync(targetDir, { recursive: true });
  }

  // Create main index.ts
  const indexContent = `// UI Components
// Generated by volt CLI

export {};
`;
  fs.writeFileSync(path.join(targetDir, 'index.ts'), indexContent);

  console.log('✅ Initialized volt/ui in', targetDir);
}

// CLI
const args = process.argv.slice(2);
const command = args[0];

if (command === 'add') {
  const componentName = args[1];
  const targetDir = args[2] || './src/app/ui';
  
  if (!componentName) {
    console.error('❌ Please specify a component name.');
    console.log('Usage: volt add <component-name> [target-dir]');
    process.exit(1);
  }

  copyComponent(componentName, targetDir);
} else if (command === 'init') {
  const targetDir = args[1] || './src/app/ui';
  initProject(targetDir);
} else if (command === 'list') {
  console.log('Available components:');
  Object.keys(components).forEach(name => console.log(`  - ${name}`));
} else {
  console.log('Volt UI CLI');
  console.log('');
  console.log('Usage:');
  console.log('  volt init [target-dir]       Initialize volt/ui in your project');
  console.log('  volt add <component>         Add a component to your project');
  console.log('  volt list                    List all available components');
  console.log('');
  console.log('Examples:');
  console.log('  volt init                    # Initialize in ./src/app/ui');
  console.log('  volt init ./src/components   # Initialize in custom directory');
  console.log('  volt add button              # Add button component');
  console.log('  volt add card                # Add card component');
}
