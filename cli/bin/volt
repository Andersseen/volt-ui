#!/usr/bin/env node

const { loadManifest, copyComponent, initProject, clearCache } = require('../lib/core');

async function main() {
  const args = process.argv.slice(2);
  const command = args[0];

  if (command === 'add') {
    const componentName = args[1];
    const targetDir = args[2] || './src/app/ui';

    if (!componentName) {
      console.error('❌ Please specify a component name.');
      console.log('Usage: volt add <component-name> [target-dir]');
      process.exit(1);
    }

    const manifest = await loadManifest();
    const result = await copyComponent(componentName, targetDir, manifest);
    console.log(`\n✅ Component "${result.componentName}" added successfully!`);

    if (result.dependencies.length > 0) {
      console.log(`\n📦 Required dependencies also copied:`);
      result.dependencies.forEach(dep => console.log(`  - ${dep}`));
    }

    console.log(`\nImport in your component:`);
    console.log(`  import { ${result.className} } from './ui/${result.componentName}';`);

    console.log(`\n⚠️  Ensure runtime dependencies are installed:`);
    console.log(`  ${result.installCommand}`);
  } else if (command === 'init') {
    const targetDir = args[1] || './src/app/ui';
    initProject(targetDir);
    console.log('✅ Initialized volt/ui in', targetDir);
  } else if (command === 'list') {
    const manifest = await loadManifest();
    console.log('Available components:');
    Object.keys(manifest.components).forEach(name => console.log(`  - ${name}`));
  } else if (command === 'clear-cache') {
    clearCache();
    console.log('✅ Cache cleared');
  } else {
    console.log('Volt UI CLI');
    console.log('');
    console.log('Usage:');
    console.log('  volt init [target-dir]       Initialize volt/ui in your project');
    console.log('  volt add <component>         Add a component to your project');
    console.log('  volt list                    List all available components');
    console.log('  volt clear-cache             Clear local component cache');
    console.log('');
    console.log('Examples:');
    console.log('  npx @voltui/cli init');
    console.log('  npx @voltui/cli add button');
    console.log('  npx @voltui/cli add card');
  }
}

main().catch(err => {
  console.error('❌ Unexpected error:', err.message);
  process.exit(1);
});
