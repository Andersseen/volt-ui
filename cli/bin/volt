function fetchFile(url) {
  return new Promise((resolve, reject) => {
    https
      .get(url, res => {
        if (res.statusCode === 301 || res.statusCode === 302) {
          fetchFile(res.headers.location).then(resolve).catch(reject);
          return;
        }

        if (res.statusCode !== 200) {
          reject(new Error(`Failed to fetch ${url}: HTTP ${res.statusCode}`));
          return;
        }

        let data = '';
        res.on('data', chunk => (data += chunk));
        res.on('end', () => resolve(data));
        res.on('error', reject);
      })
      .on('error', reject);
  });
}

function transformContent(content) {
  // Replace selector volt- with ui-
  content = content.replace(/selector:\s*['"]([^'"]*)['"]/g, (_match, selector) => {
    const newSelector = selector.replace(/volt-/g, 'ui-').replace(/\bvolt([A-Z]\w*)/g, 'ui$1');
    return `selector: '${newSelector}'`;
  });

  // Replace all VoltXxx identifiers with UiXxx (covers class declarations, exports, imports)
  content = content.replace(/\bVolt([A-Z]\w*)/g, 'Ui$1');
  content = content.replace(/\bvolt([A-Z]\w*)/g, 'ui$1');

  // Replace imports from 'volt'
  content = content.replace(/from\s+['"]volt['"]/g, "from './index'");
  content = content.replace(/from\s+['"]\.\.\/index['"]/g, "from '../index'");

  return content;
}

function capitalize(str) {
  return str
    .split(' ')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

async function copyComponent(componentName, targetDir = './src/app/ui') {
  const component = components[componentName];

  if (!component) {
    console.error(`❌ Component "${componentName}" not found.`);
    console.log('Available components:');
    Object.keys(components).forEach(name => console.log(`  - ${name}`));
    process.exit(1);
  }

  const componentDir = path.join(targetDir, componentName);

  if (!fs.existsSync(componentDir)) {
    fs.mkdirSync(componentDir, { recursive: true });
  }

  console.log(`\nFetching "${componentName}" from GitHub...`);

  for (const file of component.files) {
    const url = `${GITHUB_RAW_BASE}/${file}`;
    const fileName = path.basename(file);
    const targetPath = path.join(componentDir, fileName);

    try {
      const content = await fetchFile(url);
      const transformed = transformContent(content);
      fs.writeFileSync(targetPath, transformed);
      console.log(`  ✓ Created ${path.relative(process.cwd(), targetPath)}`);
    } catch (err) {
      console.error(`  ❌ Failed to fetch ${file}: ${err.message}`);
      process.exit(1);
    }
  }

  const className = capitalize(componentName.replace(/-/g, ' ')).replace(/\s/g, '');
  console.log(`\n✅ Component "${componentName}" added successfully!`);
  console.log(`\nImport in your component:`);
  console.log(`  import { Ui${className} } from './ui/${componentName}';`);
}

async function initProject(targetDir = './src/app/ui') {
  if (!fs.existsSync(targetDir)) {
    fs.mkdirSync(targetDir, { recursive: true });
  }

  const indexContent = `// UI Components
// Generated by volt CLI

export {};
`;
  fs.writeFileSync(path.join(targetDir, 'index.ts'), indexContent);
  console.log('✅ Initialized volt/ui in', targetDir);
}

// CLI
const args = process.argv.slice(2);
const command = args[0];

if (command === 'add') {
  const componentName = args[1];
  const targetDir = args[2] || './src/app/ui';

  if (!componentName) {
    console.error('❌ Please specify a component name.');
    console.log('Usage: volt add <component-name> [target-dir]');
    process.exit(1);
  }

  copyComponent(componentName, targetDir).catch(err => {
    console.error('❌ Unexpected error:', err.message);
    process.exit(1);
  });
} else if (command === 'init') {
  const targetDir = args[1] || './src/app/ui';
  initProject(targetDir).catch(err => {
    console.error('❌ Unexpected error:', err.message);
    process.exit(1);
  });
} else if (command === 'list') {
  console.log('Available components:');
  Object.keys(components).forEach(name => console.log(`  - ${name}`));
} else {
  console.log('Volt UI CLI');
  console.log('');
  console.log('Usage:');
  console.log('  volt init [target-dir]       Initialize volt/ui in your project');
  console.log('  volt add <component>         Add a component to your project');
  console.log('  volt list                    List all available components');
  console.log('');
  console.log('Examples:');
  console.log('  npx github:Andersseen/volt-ui init');
  console.log('  npx github:Andersseen/volt-ui add button');
  console.log('  npx github:Andersseen/volt-ui add card');
}
